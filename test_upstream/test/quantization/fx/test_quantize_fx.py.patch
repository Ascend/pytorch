+    def test_get_default_qconfig_backends(self):
+        """Validate get_default_qconfig returns QConfig with HistogramObserver for all backends."""
+        for backend in ["fbgemm", "x86", "qnnpack", "onednn"]:
+            with self.subTest(backend=backend):
+                qconfig = get_default_qconfig(backend, version=0)
+                self.assertIsInstance(qconfig, QConfig)
+                self.assertEqual(qconfig.activation.p.func, HistogramObserver)
+
+    def test_get_default_qconfig_invalid_version(self):
+        """Validate get_default_qconfig raises for version != 0."""
+        with self.assertRaisesRegex(AssertionError, "not supported"):
+            get_default_qconfig("fbgemm", version=1)
+
+    def test_get_default_qat_qconfig_backends(self):
+        """Validate get_default_qat_qconfig returns correct observer types for all backends and versions."""
+        backends = ["fbgemm", "x86", "qnnpack", "onednn"]
+        # version=0 uses FakeQuantize + MovingAverageMinMaxObserver
+        for backend in backends:
+            with self.subTest(backend=backend, version=0):
+                qconfig = get_default_qat_qconfig(backend, version=0)
+                self.assertIsInstance(qconfig, QConfig)
+                self.assertEqual(qconfig.activation.p.func, FakeQuantize)
+                self.assertEqual(qconfig.activation.p.keywords.get("observer"), MovingAverageMinMaxObserver)
+        # version=1 uses FusedMovingAvgObsFakeQuantize + MovingAverageMinMaxObserver
+        for backend in backends:
+            with self.subTest(backend=backend, version=1):
+                qconfig = get_default_qat_qconfig(backend, version=1)
+                self.assertIsInstance(qconfig, QConfig)
+                self.assertEqual(qconfig.activation.p.func, FusedMovingAvgObsFakeQuantize)
+                self.assertEqual(qconfig.activation.p.keywords.get("observer"), MovingAverageMinMaxObserver)
+
+    def test_get_default_qat_qconfig_invalid_version(self):
+        """Validate get_default_qat_qconfig raises for version not in {0, 1}."""
+        with self.assertRaisesRegex(AssertionError, "not supported"):
+            get_default_qat_qconfig("fbgemm", version=2)
+
