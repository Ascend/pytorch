+
+                cpu_gradOutput = torch.randn_like(cpu_output, requires_grad=True)
+                npu_gradOutput = cpu_gradOutput.type_as(npu_output).detach()
+                npu_gradOutput.requires_grad = True
+
+                cpu_gradInputs = torch.autograd.grad(
