+def to_npu(obj, type_map=None):
+    """Convert tensors and objects to NPU device, similar to to_gpu but for NPU.
+
+    This function uses torch.no_grad() to ensure the device transfer is not tracked
+    in the computation graph, which preserves the leaf tensor property.
+    """
+    if type_map is None:
+        type_map = {}
+    if isinstance(obj, torch.Tensor):
+        assert obj.is_leaf
+        t = type_map.get(obj.dtype, obj.dtype)
+        with torch.no_grad():
+            res = obj.to(dtype=t, device="npu", copy=True)
+            res.requires_grad = obj.requires_grad
+        return res
+    elif torch.is_storage(obj):
+        return obj.new().resize_(obj.size()).copy_(obj)  # type: ignore[attr-defined, union-attr]
+    elif isinstance(obj, list):
+        return [to_npu(o, type_map) for o in obj]
+    elif isinstance(obj, tuple):
+        return tuple(to_npu(o, type_map) for o in obj)
+    else:
+        return deepcopy(obj)
 
