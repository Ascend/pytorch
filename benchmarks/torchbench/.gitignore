# External torchbenchmark dependency (cloned from GitHub)
# These directories are created by following the instructions in README.md:
#   git clone https://github.com/pytorch/benchmark.git --depth=1
# The leading slash ensures we only ignore these directories in benchmarks/
# and not in other locations.
/benchmark/
/torchbenchmark/
